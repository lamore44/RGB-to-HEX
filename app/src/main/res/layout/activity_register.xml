<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pendaftaran Akun"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="8dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lengkapi informasi berikut untuk membuat akun baru."
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="32dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nama Lengkap"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/inputNama"
            android:hint="Masukkan nama lengkap"
            android:textColor="#212121"
            android:inputType="textPersonName"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginBottom="20dp"/>
        <!--input nim-->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NIM"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/inputNim"
            android:hint="Masukkan NIM"
            android:inputType="text"
            android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:textColor="#292828"
            android:layout_marginBottom="32dp"/>
        <!--prodi-->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Program Studi"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="4dp"/>
        <Spinner
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/spinnerProdi"
            android:background="@android:drawable/btn_dropdown"
            android:padding="8dp"
            android:layout_marginBottom="20dp"/>
        <!--gender-->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jenis Kelamin"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="4dp"/>
        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/radioGroupGender"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">
            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:id="@+id/radioMan"
                android:text="Laki-laki"
                android:textColor="#212121"
                android:layout_marginEnd="24dp"/>
            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:id="@+id/radioWoman"
                android:textColor="#212121"
                android:text="Perempuan"/>
        </RadioGroup>

        <!--hobi-->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hobi (Min 1)*"
            android:textStyle="bold"
            android:textColor="#5e0613"
            android:layout_marginBottom="4dp"/>
        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Membaca"
            android:textColor="#212121"
            android:id="@+id/cbMembaca"/>
        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/cbMusik"
            android:textColor="#212121"
            android:text="Musik"/>
        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/cbOlahraga"
            android:textColor="#212121"
            android:text="Olahraga"/>
        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/cbGaming"
            android:textColor="#212121"
            android:text="Gaming"/>
        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/cbMemasak"
            android:textColor="#212121"
            android:text="Memasak"/>
        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/cbNyawit"
            android:textColor="#212121"
            android:text="Nyawit"
            android:layout_marginBottom="28dp"/>
        <!--tombol daftar-->
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/btnDaftar"
            android:text="Lihat profil"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>
        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kembali"
            android:id="@+id/btnKembali"/>
    </LinearLayout>
</ScrollView>
