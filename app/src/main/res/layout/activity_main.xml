<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Judul Aplikasi -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Generator Warna HEX"
            android:textColor="#212121"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Merah -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Red (R)"
            android:textColor="#F44336"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp">

            <SeekBar
                android:id="@+id/seekBarR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255"
                android:progressTint="#F44336"/>

            <EditText
                android:id="@+id/inputR"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:inputType="number"
                android:text="0"
                android:textAlignment="center"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Hijau -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Green (G)"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp">

            <SeekBar
                android:id="@+id/seekBarG"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255"
                android:progressTint="#4CAF50"/>

            <EditText
                android:id="@+id/inputG"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:inputType="number"
                android:text="0"
                android:textAlignment="center"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Biru -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Blue (B)"
            android:textColor="#2196F3"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp">

            <SeekBar
                android:id="@+id/seekBarB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255"
                android:progressTint="#2196F3"/>

            <EditText
                android:id="@+id/inputB"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="0"
                android:textAlignment="center"
                android:textColor="#000000"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Tombol Generate -->
        <Button
            android:id="@+id/btnGenerate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generate Warna"
            android:layout_marginBottom="16dp"/>

        <!-- Kotak Preview Warna -->
        <View
            android:id="@+id/colorPreview"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#000000"
            android:layout_marginBottom="16dp"/>

        <!-- Kode HEX -->
        <TextView
            android:id="@+id/tvHexCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kode HEX: #000000"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="8dp"/>

        <!-- Nama Warna -->
        <TextView
            android:id="@+id/tvColorName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:text="Nama Warna: -"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginBottom="16dp"/>

        <!-- Tombol Salin HEX -->
        <Button
            android:id="@+id/btnCopy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salin Kode HEX"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/btnGoToRegister"
            android:text="Daftar Profil"
            android:layout_marginTop="16dp"
            android:backgroundTint="#607D8B"/>

    </LinearLayout>
</ScrollView>